.git
.github
Makefile
*.md
# Allow Gradle wrapper for multi-stage builds
!gradle/
!gradlew
!gradlew.bat
# Allow otel-extension source for building
!otel-extension/
# Block example source directories (keep only example Dockerfiles/configs)
examples/*/src/
!examples/
# Allow the pre-built pyroscope-otel jars needed by example Dockerfiles
!otel-extension/build/libs/
!otel-extension/build/libs/pyroscope-otel-javaagent-extension.jar
!lib/build/libs/
!lib/build/libs/pyroscope-otel.jar
